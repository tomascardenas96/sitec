---
import Footer from "../components/common/Footer.astro";
import Header from "../components/common/Header.astro";
import MidBar from "../components/common/Mid-bar.astro";
import TopBar from "../components/common/Top-bar.astro";
import WhatsappBtn from "../components/common/WhatsappBtn.astro";
import "../styles/globals.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:ital,opsz,wght,SOFT@0,9..144,200..900,30..100;1,9..144,200..900,30..100&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>BALCA — Soluciones eléctricas industriales</title>
  </head>
  <body class="bg-paper text-ink overflow-x-hidden">
    <TopBar />
    <Header />
    <slot />
    <WhatsappBtn />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>

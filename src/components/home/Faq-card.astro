---
const { question, answer, id, index = "01" } = Astro.props;
---

<details class="group border-b border-ink/20 last:border-b-0">
  <summary class="cursor-pointer list-none py-6 lg:py-7 px-2 flex items-start gap-5 hover:bg-paper-deep/50 transition-colors">
    <span class="font-mono text-[11px] tracking-[0.28em] uppercase text-rust pt-1 shrink-0">
      [ {index} ]
    </span>
    <span class="font-display text-xl lg:text-2xl uppercase tracking-tight text-ink flex-1 leading-tight">
      {question}
    </span>
    <span class="font-mono text-2xl text-ink/40 group-open:rotate-45 transition-transform duration-300 shrink-0">
      +
    </span>
  </summary>
  <div class="pb-7 px-2 pl-[3.4rem] -mt-2">
    <p class="font-serif text-base lg:text-lg leading-[1.55] text-ink/70 max-w-[68ch]">
      {answer}
    </p>
  </div>
</details>

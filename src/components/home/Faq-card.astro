---
const { question, answer, id } = Astro.props;
import DownArrow from "../../assets/icons/down-arrow.svg";
import LightBulb from "../../assets/icons/light.svg";
---

<details
  class="group rounded-2xl shadow-soft bg-white ring-1 ring-neutral-200/70 hover:ring-primary-200 transition-all md:w-[42.5rem] lg:w-[44rem] xl:w-[52rem] 2xl:w-[58rem] open:shadow-card open:ring-primary-300"
>
  <summary
    class="flex items-center justify-between cursor-pointer gap-4 px-6 py-5 lg:py-4 xl:py-4 2xl:py-5 text-sm lg:text-sm font-medium list-none"
  >
    <div class="hidden xl:flex h-9 w-9 rounded-full bg-primary-50 items-center justify-center shrink-0 ring-1 ring-primary-100">
      <LightBulb class="h-5 w-5 text-primary-500"/>
    </div>
    <span class="flex-1 text-neutral-700">{question}</span>
    <div class="h-8 w-8 rounded-full bg-primary-50 flex items-center justify-center shrink-0 transition-transform duration-300 group-open:rotate-180 group-open:bg-primary-100">
      <DownArrow class="h-4 w-4 text-primary-500" />
    </div>
  </summary>

  <div class="px-6 pb-6 pt-2 text-sm lg:text-sm text-neutral-500 leading-relaxed">
    <div class="pl-0 xl:pl-[3.25rem] border-t border-neutral-100 pt-4">
      {answer}
    </div>
  </div>
</details>

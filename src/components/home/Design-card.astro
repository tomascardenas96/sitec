---
const { description, icon, index = 0 } = Astro.props;
const delay = (index % 4) * 100;
---

<div
  class="group flex flex-col gap-3 md:gap-4 items-center"
  data-reveal="fade-up"
  data-reveal-delay={delay}
>
  <div
    class="w-[10rem] h-[10rem] md:w-[15rem] lg:w-[10rem] xl:w-[12.8rem] md:h-[15rem] lg:h-[10rem] xl:h-[12.8rem] bg-white rounded-md flex items-center justify-center transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-elevated"
  >
    <img
      src={icon.src}
      alt={description}
      class="w-[5rem] md:w-[6rem] xl:w-[6rem] h-[5rem] md:h-[6rem] xl:h-[6rem] object-contain opacity-80 transition-opacity duration-300 group-hover:opacity-100"
    />
  </div>

  <p
    class="text-center font-light text-xs md:text-base lg:text-xs xl:text-sm 2xl:text-base max-w-[26ch] xl:max-w-[24ch] text-white md:leading-6 lg:leading-5 xl:leading-[1.4rem]"
  >
    {description}
  </p>
</div>

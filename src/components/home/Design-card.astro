---
const { description, icon } = Astro.props;
---

<div class="flex flex-col gap-4 md:gap-5 items-center group">
  <div
    class="w-[10rem] h-[10rem] md:w-[15rem] lg:w-[11rem] xl:w-[13.5rem] 2xl:w-[14.5rem] md:h-[15rem] lg:h-[11rem] xl:h-[13.5rem] 2xl:h-[14.5rem] bg-white/95 rounded-3xl flex items-center justify-center shadow-elevated ring-1 ring-white/40 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-elevated group-hover:ring-accent-200"
  >
    <img
      src={icon.src}
      alt={description}
      class="w-[5rem] md:w-[6rem] xl:w-[6.5rem] h-[5rem] md:h-[6rem] xl:h-[6.5rem] object-contain opacity-90"
    />
  </div>

  <p
    class="text-center font-light text-xs md:text-base lg:text-xs xl:text-sm 2xl:text-base max-w-[26ch] xl:max-w-[24ch] text-white md:leading-6 lg:leading-5 xl:leading-[1.4rem] tracking-wide"
  >
    {description}
  </p>
</div>

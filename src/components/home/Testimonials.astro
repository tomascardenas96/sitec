---
import { testimonials } from "../../data/testimonials";
import Testimonial from "./Testimonial.card.astro";
---

<section class="relative bg-paper-deep py-20 lg:py-32 overflow-hidden">
  <div
    class="absolute inset-0 bg-blueprint-grid-sm opacity-50 pointer-events-none"
  >
  </div>

  <div class="max-w-[1400px] mx-auto px-5 lg:px-12 relative">
    <!-- Header -->
    <div class="grid lg:grid-cols-12 gap-6 mb-14 lg:mb-20">
      <div
        class="lg:col-span-2 flex items-start gap-3 font-mono text-[10px] tracking-[0.28em] uppercase text-rust"
      >
        <span>[ 05 ]</span>
        <span>—</span>
      </div>
      <div class="lg:col-span-7 lg:col-start-2">
        <div
          class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink/55 mb-4"
        >
          § Voces de obra
        </div>
        <h2
          class="font-display uppercase leading-[0.9] tracking-tight text-[3rem] md:text-[5rem] lg:text-[6rem] text-ink"
        >
          La palabra<br />
          <span class="fraunces-italic font-normal text-rust normal-case"
            >del cliente</span
          >.
        </h2>
      </div>
    </div>

    <!-- Featured pull quote -->
    <div class="grid lg:grid-cols-12 gap-8 mb-16 lg:mb-24 items-start">
      <div
        class="lg:col-span-1 lg:col-start-3 font-display text-[8rem] lg:text-[8rem] leading-[0.6] text-amber"
      >
        "
      </div>
      <div class="lg:col-span-7">
        <blockquote
          class="font-serif text-2xl lg:text-4xl leading-[1.25] text-ink"
        >
          {testimonials[0]?.body}
        </blockquote>
        <div class="mt-8 flex items-center gap-4">
          <div class="block w-12 h-px bg-ink"></div>
          <div
            class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink"
          >
            {testimonials[0]?.name}
          </div>
        </div>
      </div>
    </div>

    <!-- Secondary testimonials -->
    <div
      class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 border-t border-ink/15 pt-10"
    >
      {
        testimonials
          .slice(1)
          .map((t, i) => (
            <Testimonial
              image={t.image}
              name={t.name}
              body={t.body}
              index={String(i + 2).padStart(2, "0")}
            />
          ))
      }
      <!-- Stat card to balance -->
      <div
        class="bg-ink text-paper p-8 lg:p-10 flex flex-col justify-between min-h-[18rem]"
      >
        <div
          class="font-mono text-[10px] tracking-[0.28em] uppercase text-amber"
        >
          [ INDICADOR · 2025 ]
        </div>
        <div>
          <div class="font-display text-7xl lg:text-8xl leading-none">
            98<span class="text-amber">%</span>
          </div>
          <div
            class="font-mono text-[11px] tracking-[0.25em] uppercase text-paper/65 mt-3"
          >
            Clientes recurrentes
          </div>
          <p class="font-serif italic text-sm text-paper/55 mt-4 max-w-[28ch]">
            La mayor parte de nuestra obra anual proviene de clientes que ya nos
            conocen.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

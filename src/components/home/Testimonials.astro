---
import texture from "../../assets/images/textura.png";
import SectionTitle from "../ui/SectionTitle.astro";
import Like from "../../assets/icons/like.svg";
import { testimonials } from "../../data/testimonials";
import Testimonial from "./Testimonial.card.astro";
---

<section
  class="mt-2 py-14 2xl:py-20 px-5 bg-cover pb-24 xl:pb-28 2xl:pb-32 md:flex md:flex-col md:items-center relative"
  style={`background-image: url('${texture.src}')`}
>
  <div class="absolute inset-0 bg-gradient-to-b from-primary-900/35 via-transparent to-primary-900/40 pointer-events-none"></div>

  <SectionTitle
    label="Testimonios de Clientes"
    subtitle="Experiencia, innovación y resultados comprobados en cada uno de nuestros trabajos"
    variant="inverse"
    hasIcon={true}
    class="relative z-10"
  >
    <Like slot="icon" />
  </SectionTitle>

  <div
    class="relative z-10 grid md:flex gap-6 md:gap-8 lg:gap-7 xl:gap-9 2xl:gap-10 mt-10 md:mt-12 md:max-w-[42.5rem] lg:max-w-[56rem] xl:max-w-[68rem] 2xl:max-w-[74rem] lg:w-full xl:w-full 2xl:w-full md:overflow-auto lg:overflow-visible lg:grid lg:grid-cols-3"
  >
    {
      testimonials.map((testimonial) => (
        <Testimonial
          image={testimonial.image}
          name={testimonial.name}
          body={testimonial.body}
        />
      ))
    }
  </div>
</section>

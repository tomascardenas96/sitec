---
const { image, name, body, index = "01" } = Astro.props;
---

<article class="group bg-paper border border-ink/15 p-7 lg:p-8 flex flex-col gap-5 min-h-[18rem] hover:border-ink transition-colors">
  <div class="flex items-baseline gap-3 font-mono text-[10px] tracking-[0.28em] uppercase">
    <span class="text-rust">[ {index} ]</span>
    <span class="flex-1 h-px bg-ink/15 group-hover:bg-rust transition-colors"></span>
    <span class="text-amber">"</span>
  </div>

  <p class="font-serif text-[15px] leading-[1.55] text-ink/85 flex-1">
    {body}
  </p>

  <div class="flex items-center gap-3 pt-4 border-t border-ink/10">
    <img
      src={image.src}
      alt={name}
      class="w-10 h-10 rounded-full object-cover grayscale group-hover:grayscale-0 transition-all"
    />
    <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-ink">
      {name}
    </div>
  </div>
</article>

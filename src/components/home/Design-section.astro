---
import SectionTitle from "../ui/SectionTitle.astro";
import { shortFlow } from "../../data/design-flow.js";
import DesignCard from "./Design-card.astro";
---

<section class="relative bg-ink text-paper py-20 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.07] pointer-events-none"
       style="background-image: linear-gradient(rgba(244,241,234,1) 1px, transparent 1px), linear-gradient(90deg, rgba(244,241,234,1) 1px, transparent 1px); background-size: 48px 48px;">
  </div>

  <!-- Corner brackets -->
  <div class="hidden lg:block absolute top-8 left-8 font-mono text-[10px] tracking-[0.28em] uppercase text-amber">
    [ 03 · METODOLOGÍA ]
  </div>
  <div class="hidden lg:flex absolute top-8 right-8 font-mono text-[10px] tracking-[0.28em] uppercase text-paper/50 items-center gap-2">
    <span>4 ETAPAS</span>
    <span class="text-amber">/</span>
    <span>FLUJO DE PROYECTO</span>
  </div>

  <div class="max-w-[1400px] mx-auto px-5 lg:px-12 relative">
    <SectionTitle
      label="Diseño con criterio"
      subtitle="De la idea al circuito energizado. Cada etapa documentada, cada decisión trazable."
      variant="inverse"
      index="03"
    />

    <!-- Process timeline -->
    <div class="mt-16 lg:mt-24">
      <!-- Horizontal rule with markers -->
      <div class="hidden lg:flex items-center mb-12 relative">
        <div class="absolute inset-x-0 top-1/2 h-px bg-paper/15"></div>
        {shortFlow.map((_, i) => (
          <div class="flex-1 flex justify-center">
            <div class="relative w-3 h-3 bg-ink border border-amber rounded-full z-10">
              {i === 0 && <div class="absolute inset-0 rounded-full bg-amber animate-pulse-amber"></div>}
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-y-12 lg:gap-x-6">
        {shortFlow.map((item, i) => (
          <DesignCard description={item.title} icon={item.icon} index={i + 1} />
        ))}
      </div>
    </div>

    <!-- Bottom note -->
    <div class="mt-20 grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-7">
        <p class="font-serif text-2xl lg:text-3xl leading-snug text-paper/90 max-w-[42ch]">
          <span class="fraunces-italic text-amber">"</span>El método no es burocracia —
          es la diferencia entre un tablero que dura una década y uno que falla en el primer
          arranque.<span class="fraunces-italic text-amber">"</span>
        </p>
      </div>
      <div class="lg:col-span-4 lg:col-start-9">
        <a
          href="/design"
          class="group inline-flex items-center gap-4 font-display tracking-[0.18em] uppercase text-sm text-paper hover:text-amber transition-colors"
        >
          <span class="inline-block w-12 h-px bg-paper/40 group-hover:bg-amber group-hover:w-20 transition-all"></span>
          <span>Ver flujo completo</span>
          <span>→</span>
        </a>
      </div>
    </div>
  </div>
</section>

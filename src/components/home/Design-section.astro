---
import texture from "../../assets/images/textura.png";
import Rocket from "../../assets/icons/rocket.svg";
import SectionTitle from "../ui/SectionTitle.astro";
import { shortFlow } from "../../data/design-flow.js";
import DesignCard from "./Design-card.astro";
---

<section
  class="mt-3 py-14 2xl:py-20 lg:pb-24 2xl:pb-32 px-2 bg-cover md:flex md:flex-col md:items-center relative"
  style={`background-image: url('${texture.src}')`}
>
  <div class="absolute inset-0 bg-gradient-to-b from-primary-900/30 via-transparent to-primary-900/40 pointer-events-none"></div>

  <SectionTitle
    label="Diseño de Proyectos"
    subtitle="Transformando ideas en soluciones eléctricas confiables y eficientes"
    variant="inverse"
    hasIcon={true}
    class="relative z-10"
  >
    <Rocket slot="icon" />
  </SectionTitle>

  <div
    class="relative z-10 grid
          grid-cols-2
          lg:grid-cols-4
          grid-rows-2
          lg:grid-rows-1
          gap-y-8
          md:gap-x-16
          lg:gap-x-5
          xl:gap-x-7
          mt-10
          md:mt-12
          px-5
          lg:px-0
          md:max-w-[43.75rem]
          lg:max-w-[58rem]
          xl:max-w-[68rem]
          2xl:max-w-[74rem]
          xl:w-full
          2xl:w-full
          xl:py-2"
  >
    {
      shortFlow.map((item) => (
        <DesignCard description={item.title} icon={item.icon} />
      ))
    }
  </div>
</section>

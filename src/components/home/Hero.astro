---
import hero from "../../assets/images/f5d41eb7-25c9-48a8-8e4f-95947947fa13.png";
import Wallet from "../../assets/icons/wallet.svg";
const phone = "5492281378525";
const text =
  "Buen día, quisiera solicitar un presupuesto para la instalación de paneles eléctricos en mi empresa. Muchas gracias.";
const encoded = encodeURIComponent(text);
---

<section
  class="h-96 lg:h-[19rem] xl:h-[21.9rem] 2xl:h-[24rem] relative flex items-center justify-center bg-cover bg-center flex-col gap-8 lg:gap-5 xl:gap-5"
  style={`background-image: url('${hero.src}');`}
>
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Mobile hero title -->
  <div class="p-6 border-2 border-white z-10 rounded-[.2rem] lg:hidden">
    <h1
      class="relative text-white text-3xl tracking-[0.02em] font-[400] z-10 flex text-center font-oswald max-w-[20ch]"
    >
      SOLUCIONES ELECTRICAS E INDUSTRIALES
    </h1>
  </div>

  <!-- Desktop hero title -->
  <div class="z-10 rounded-[.2rem] hidden pt-14 lg:block">
    <h1
      class="w-[35ch] relative text-white text-3xl xl:text-3xl 2xl:text-4xl font-[400] z-10 flex text-center font-oswald leading-9 xl:leading-10 2xl:leading-[3rem] tracking-[.04em] xl:tracking-[.05em]"
    >
      Soluciones eléctricas integrales y montajes industriales
    </h1>
  </div>

  <a
    href={`https://wa.me/${phone}?text=${encoded}`}
    target="blank"
    class="bg-cta-gradient relative cursor-pointer z-10 text-sm lg:text-xs xl:text-sm h-12 lg:h-10 xl:h-11 2xl:h-12 w-52 lg:w-44 xl:w-52 2xl:w-56 flex items-center justify-center gap-2 2xl:gap-3 rounded-md shadow-elevated text-white font-oswald font-medium lg:font-normal"
  >
    <Wallet class="hidden 2xl:inline w-5 h-5 shadow-md" /> SOLICITAR PRESUPUESTO
  </a>
</section>

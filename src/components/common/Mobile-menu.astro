---
const items = [
  { href: "/", label: "Inicio", num: "01" },
  { href: "/about-us", label: "Nosotros", num: "02" },
  { href: "/design", label: "Diseño", num: "03" },
  { href: "/projects", label: "Proyectos", num: "04" },
  { href: "/contact", label: "Contacto", num: "05" },
];
---

<nav
  id="menu"
  data-open="false"
  class="fixed inset-0 z-40 bg-paper hidden flex-col lg:hidden"
>
  <div class="flex items-center justify-between px-5 h-16 border-b border-ink/10">
    <span class="font-display text-2xl tracking-tight">SITEC</span>
    <button id="closeModal" class="font-mono text-[11px] tracking-[0.2em] uppercase flex items-center gap-2">
      <span>Cerrar</span>
      <span class="text-xl leading-none">×</span>
    </button>
  </div>

  <div class="flex-1 flex flex-col justify-between px-6 py-8">
    <ul class="flex flex-col gap-2">
      {items.map((item) => (
        <li class="border-b border-ink/10 py-3">
          <a href={item.href} class="flex items-baseline gap-4 group">
            <span class="font-mono text-[10px] tracking-widest text-ink/40 group-hover:text-amber transition">{item.num}</span>
            <span class="font-display text-4xl tracking-tight uppercase">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-10">
      <div class="font-mono text-[10px] tracking-[0.25em] uppercase text-ink/50 mb-3">
        — Solicitar presupuesto
      </div>
      <a
        href="/contact"
        class="inline-flex items-center justify-between w-full bg-ink text-paper px-5 py-4 font-display text-xl tracking-wide uppercase"
      >
        <span>Escribinos</span>
        <span class="text-amber">⚡</span>
      </a>
    </div>
  </div>
</nav>

<style>
  nav[data-open="true"] {
    display: flex !important;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const burger = document.getElementById("burger");
    const menu = document.getElementById("menu");
    const closeBtn = document.getElementById("closeModal");
    if (!burger || !menu || !closeBtn) return;

    burger.addEventListener("click", () => {
      menu.dataset.open = "true";
      burger.dataset.open = "true";
      document.body.style.overflow = "hidden";
    });

    const close = () => {
      menu.dataset.open = "false";
      burger.dataset.open = "false";
      document.body.style.overflow = "";
    };

    closeBtn.addEventListener("click", close);

    menu.addEventListener("click", (e) => {
      if (e.target === menu) close();
    });
  });
</script>

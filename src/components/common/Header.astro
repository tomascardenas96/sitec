---
import menu from "../../assets/icons/menu.svg";
import HeaderList from "./Header-list.astro";
import MobileMenu from "./Mobile-menu.astro";
import SocialHeader from "./Social-header.astro";
---

<header
  id="header-container"
  class="sticky top-0 z-30 bg-paper/85 backdrop-blur-md border-b border-ink/10"
>
  <div
    class="max-w-[1400px] mx-auto px-5 lg:px-10 h-16 lg:h-20 flex items-center justify-between gap-8"
  >
    <a href="/" class="flex items-baseline gap-3 group">
      <span
        class="font-display text-2xl lg:text-3xl tracking-tight text-ink leading-none"
      >
        BALCA
      </span>
      <span
        class="hidden lg:flex items-center gap-2 font-mono text-[10px] tracking-[0.25em] uppercase text-ink/60"
      >
        <span class="voltage-dot"></span>
        <span>EST. 2008 · AR</span>
      </span>
    </a>

    <div class="hidden lg:flex items-center gap-10">
      <HeaderList />
      <div class="h-5 w-px bg-ink/15"></div>
      <SocialHeader />
      <a
        href="/contact"
        class="group inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-ink hover:text-rust transition-colors"
      >
        <span>Presupuesto</span>
        <span
          class="inline-block w-6 h-px bg-ink group-hover:bg-rust group-hover:w-10 transition-all"
        ></span>
        <span>↗</span>
      </a>
    </div>

    <button
      id="burger"
      class="lg:hidden flex flex-col gap-[5px] justify-center items-end w-10 h-10"
      aria-label="Abrir menú"
      data-open="false"
    >
      <span class="block h-[2px] w-7 bg-ink transition-all"></span>
      <span class="block h-[2px] w-5 bg-ink transition-all"></span>
      <span class="block h-[2px] w-7 bg-ink transition-all"></span>
    </button>

    <MobileMenu />
  </div>
</header>

---
const { image, title, subtitle, id, featured = false, index = "01" } = Astro.props;
---

<article class={`group relative ${featured ? "h-full" : ""}`}>
  <a href={`/projects/preview/${id}`} class="block relative h-full">
    <div class={`relative overflow-hidden border border-ink/15 bg-ink ${featured ? "aspect-[4/5] lg:aspect-auto lg:h-full lg:min-h-[36rem]" : "aspect-[4/3]"}`}>
      <img
        src={image.src}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/20 to-transparent"></div>

      <!-- Corner index -->
      <div class="absolute top-4 left-4 flex items-center gap-2">
        <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-paper bg-ink/60 backdrop-blur px-2 py-1 border border-paper/20">
          [ {index} ]
        </span>
        {featured && (
          <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink bg-amber px-2 py-1">
            DESTACADO
          </span>
        )}
      </div>

      <!-- Hover arrow -->
      <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-paper text-ink flex items-center justify-center opacity-0 group-hover:opacity-100 group-hover:translate-x-0 translate-x-2 transition-all duration-300">
        ↗
      </div>

      <!-- Caption -->
      <div class="absolute inset-x-0 bottom-0 p-5 lg:p-7 text-paper">
        <div class="font-mono text-[10px] tracking-[0.28em] uppercase text-amber mb-3">
          · {featured ? "Obra principal" : "Obra"}
        </div>
        <h3 class={`font-display uppercase tracking-tight leading-[0.95] ${featured ? "text-3xl lg:text-5xl" : "text-2xl lg:text-3xl"}`}>
          {title}
        </h3>
        <p class={`font-serif italic mt-3 text-paper/75 ${featured ? "text-lg max-w-[40ch]" : "text-sm max-w-[32ch]"}`}>
          {subtitle}
        </p>
      </div>
    </div>
  </a>
</article>

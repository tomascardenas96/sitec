---
const { image, title, subtitle, id, index = 0 } = Astro.props;
const delay = (index % 3) * 90;
---

<artice
  class="group w-full h-80 lg:h-72 border shadow-sm bg-white overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-elevated"
  data-reveal="fade-up"
  data-reveal-delay={delay}
>
  <a
    href={`/projects/preview/${id}`}
    class="grid grid-rows-[13.5rem_1fr] lg:grid-rows-[11.5rem_1fr] text-inherit"
  >
    <div class="border-b overflow-hidden">
      <img
        src={image.src}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    </div>

    <div class="flex flex-col pt-4 lg:pt-2 lg:gap-[.1rem]">
      <h1
        class="font-oswald text-xl lg:text-lg 2xl:text-xl text-center text-primary-500 transition-colors duration-200 group-hover:text-accent-500"
      >
        {title}
      </h1>
      <h2
        class="text-center md:max-w-[25ch] lg:max-w-[32ch] md:self-center lg:text-xs 2xl:text-sm"
      >
        {subtitle}
      </h2>
    </div>
  </a>
</artice>

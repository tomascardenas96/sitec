---
const currentPath = Astro.url.pathname;
const items = [
  { href: "/", label: "Inicio", num: "01" },
  { href: "/about-us", label: "Nosotros", num: "02" },
  { href: "/design", label: "Diseño", num: "03" },
  { href: "/projects", label: "Proyectos", num: "04" },
  { href: "/contact", label: "Contacto", num: "05" },
];
---

<ul id="main-menu" class="flex gap-7 xl:gap-9 items-center">
  {items.map((item) => {
    const active = currentPath.replace(/\/$/, "") === item.href.replace(/\/$/, "");
    return (
      <li class="group relative">
        <a
          href={item.href}
          class={`flex items-baseline gap-2 font-display text-[15px] tracking-wide uppercase transition-colors ${active ? "text-ink" : "text-ink/70 hover:text-ink"}`}
        >
          <span class={`font-mono text-[9px] tracking-widest ${active ? "text-amber" : "text-ink/40 group-hover:text-amber"}`}>
            {item.num}
          </span>
          <span>{item.label}</span>
        </a>
        <span
          class={`absolute -bottom-1 left-0 h-[2px] bg-ink transition-all duration-300 ${active ? "w-full" : "w-0 group-hover:w-full"}`}
        ></span>
      </li>
    );
  })}
</ul>

<script is:inline>
  const currentPath = window.location.pathname.replace(/\/$/, "");
  document.querySelectorAll("#main-menu a").forEach((link) => {
    const href = link.getAttribute("href").replace(/\/$/, "");
    if (href === currentPath) {
      link.classList.remove("text-ink/70");
      link.classList.add("text-ink");
    }
  });
</script>

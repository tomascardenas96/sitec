---
import Facebook from "../../assets/icons/facebook.svg";
import Instagram from "../../assets/icons/instagram.svg";
import Linkedin from "../../assets/icons/linkedin.svg";
import { phone, encoded } from "../../data/whatsapp.js";

const sections = [
  { href: "/", label: "Inicio", num: "01" },
  { href: "/about-us", label: "Nosotros", num: "02" },
  { href: "/design", label: "Diseño", num: "03" },
  { href: "/projects", label: "Proyectos", num: "04" },
  { href: "/contact", label: "Contacto", num: "05" },
];
---

<footer class="relative bg-ink text-paper overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: linear-gradient(rgba(244,241,234,1) 1px, transparent 1px), linear-gradient(90deg, rgba(244,241,234,1) 1px, transparent 1px); background-size: 48px 48px;"
  >
  </div>

  <!-- Big mark -->
  <div class="relative border-b border-paper/15">
    <div class="max-w-[1400px] mx-auto px-5 lg:px-12 py-12 lg:py-16">
      <div class="grid lg:grid-cols-12 gap-6 items-center">
        <div class="lg:col-span-8">
          <div
            class="font-mono text-[11px] tracking-[0.28em] uppercase text-amber mb-4"
          >
            — Contactanos hoy
          </div>
          <h2
            class="font-display uppercase leading-[0.9] text-[3.5rem] md:text-[6rem] lg:text-[3rem]"
          >
            Pongamos tu<br />
            <span class="fraunces-italic font-normal text-amber normal-case"
              >planta en marcha</span
            >.
          </h2>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <a
            href={`https://wa.me/${phone}?text=${encoded}`}
            target="_blank"
            class="group inline-flex items-center gap-3 bg-amber text-ink px-7 h-14 font-display tracking-[0.18em] uppercase text-sm hover:bg-paper transition-colors"
          >
            <span>Solicitar presupuesto</span>
            <span>⚡</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer info -->
  <div class="relative max-w-[1400px] mx-auto px-5 lg:px-12 py-14 lg:py-20">
    <div class="grid lg:grid-cols-12 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <div class="flex items-baseline gap-3 mb-5">
          <span class="font-display text-4xl tracking-tight">BALCA</span>
          <span
            class="font-mono text-[10px] tracking-[0.28em] uppercase text-paper/50"
          >
            EST · 2008
          </span>
        </div>
        <p
          class="font-serif text-base text-paper/65 max-w-[42ch] leading-[1.55]"
        >
          Soluciones eléctricas y electromecánicas. Del diseño hasta el montaje
          y puesta en marcha de tableros, bajo todas las normas de seguridad
          vigentes.
        </p>

        <div class="flex items-center gap-3 mt-7">
          <a
            href="https://www.facebook.com"
            target="_blank"
            class="w-10 h-10 border border-paper/25 flex items-center justify-center hover:bg-amber hover:border-amber hover:text-ink transition-colors bg-white"
          >
            <Facebook class="w-4 h-4" />
          </a>
          <a
            href="https://www.instagram.com"
            target="_blank"
            class="w-10 h-10 border border-paper/25 flex items-center justify-center hover:bg-amber hover:border-amber hover:text-ink transition-colors bg-white"
          >
            <Instagram class="w-4 h-4" />
          </a>
          <a
            href="https://www.linkedin.com"
            target="_blank"
            class="w-10 h-10 border border-paper/25 flex items-center justify-center hover:bg-amber hover:border-amber hover:text-ink transition-colors bg-white"
          >
            <Linkedin class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Nav -->
      <div class="lg:col-span-3 lg:col-start-6">
        <div
          class="font-mono text-[10px] tracking-[0.28em] uppercase text-paper/50 mb-5"
        >
          § Navegación
        </div>
        <ul class="flex flex-col gap-2">
          {
            sections.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="group flex items-baseline gap-3 font-display text-base tracking-wide uppercase text-paper/85 hover:text-amber transition-colors"
                >
                  <span class="font-mono text-[10px] tracking-widest text-paper/40 group-hover:text-amber transition-colors">
                    {s.num}
                  </span>
                  <span>{s.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3 lg:col-start-10">
        <div
          class="font-mono text-[10px] tracking-[0.28em] uppercase text-paper/50 mb-5"
        >
          § Coordenadas
        </div>
        <ul class="flex flex-col gap-4 font-serif text-base text-paper/85">
          <li>
            <div
              class="font-mono text-[10px] tracking-widest uppercase text-paper/40 mb-1"
            >
              Sede
            </div>
            <div>Azul · Buenos Aires · AR</div>
          </li>
          <li>
            <div
              class="font-mono text-[10px] tracking-widest uppercase text-paper/40 mb-1"
            >
              Teléfono
            </div>
            <div>(2494) 123 456</div>
          </li>
          <li>
            <div
              class="font-mono text-[10px] tracking-widest uppercase text-paper/40 mb-1"
            >
              Horario
            </div>
            <div>Lun–Vie · 08:00 — 18:00</div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Legal -->
    <div
      class="mt-16 pt-6 border-t border-paper/15 flex flex-col md:flex-row md:items-center justify-between gap-3 font-mono text-[10px] tracking-[0.25em] uppercase text-paper/45"
    >
      <div>© 2026 · BALCA · TODOS LOS DERECHOS RESERVADOS</div>
      <div>SITIO POR · TOMÁS CÁRDENAS — TOMASCARDENAS.ME</div>
    </div>
  </div>
</footer>

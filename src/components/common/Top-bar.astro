---
const items = [
  "ENERGÍA · SEGURA · CONFIABLE",
  "TABLEROS IEC 61439",
  "MONTAJES ELECTROMECÁNICOS",
  "SERVICIO 24/7",
  "DESDE 2008",
  "AZUL · BUENOS AIRES · AR",
  "v.380 / 60Hz",
  "TEL · (2494) 123 456",
];
---

<nav
  id="top-bar-container"
  class="hidden lg:flex w-full h-9 bg-ink text-paper font-mono text-[10px] tracking-[0.22em] uppercase items-center overflow-hidden border-b border-amber/30"
>
  <div class="marquee-track gap-10 px-6">
    {[...items, ...items, ...items].map((t, i) => (
      <span class="flex items-center gap-3 shrink-0">
        <span class="text-amber">◆</span>
        <span>{t}</span>
      </span>
    ))}
  </div>
</nav>

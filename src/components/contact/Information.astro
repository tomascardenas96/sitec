---
import { information } from "../../data/contact.js";
import RightArrowIcon from "../../assets/icons/right-arrow.svg";
import InfoCard from "./Info-card.astro";
const phone = "5492281378525";
---

<section
  class="px-4 lg:px-0 lg:h-[18.0831rem] xl:h-[20.8331rem] 2xl:h-[21.3331rem]"
>
  <div class="pt-7 lg:pt-2 pb-5 lg:pb-5 2xl:pb-7 lg:flex">
    <!-- <SectionTitle label="Datos de Contacto" /> -->
    <div class=`flex flex-col justify-center items-center gap-2 `>
      <div class="flex gap-2 justify-center items-center">
        <h1
          class=`text-2xl 2xl:text-3xl font-oswald font-normal text-primary-500`
        >
          Datos de Contacto
        </h1>
      </div>
    </div>
  </div>

  <div
    class="grid grid-cols-2 gap-y-6 lg:gap-y-6 xl:gap-y-7 2xl:gap-y-6 gap-x-8 lg:gap-x-7 xl:gap-x-0 2xl:gap-x-10 pl-[4%] lg:pl-0"
  >
    {
      information.map((item) => (
        <InfoCard
          title={item.title}
          firstLine={item.firstLine}
          secondLine={item.secondLine}
          icon={item.icon}
        />
      ))
    }
  </div>

  <p class="mt-11 flex items-center gap-2 text-xs">
    <a
      href={`https://wa.me/${phone}`}
      target="blank"
      class="flex items-center gap-2 text-neutral-600 underline"
    >
      <RightArrowIcon class="w-4 h-4" /> Solicitá tu cotización y responderemos a
      la brevedad
    </a>
  </p>
</section>

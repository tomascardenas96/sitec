---
interface Props {
  variant?: "primary" | "outline" | "floating" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  target?: string;
  fullWidth?: boolean;
  class?: string;
}

const {
  variant = "outline",
  size = "md",
  href,
  target,
  fullWidth = false,
  class: className = "",
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: "h-8 px-4 text-xs",
  md: "h-10 px-8 text-sm lg:text-xs 2xl:text-base",
  lg: "h-12 px-12 text-base",
};

const variantClasses: Record<string, string> = {
  primary:  "bg-cta-gradient text-white shadow-elevated rounded-md font-medium",
  outline:  "border-2 border-primary-500 text-primary-500 shadow-card font-normal",
  floating: "bg-success rounded-full p-4 shadow-card fixed bottom-10 lg:bottom-12 right-5 lg:right-10 z-40 cursor-pointer",
  ghost:    "text-primary-500 hover:bg-primary-50 rounded-md",
};

const base = "font-oswald inline-flex items-center justify-center cursor-pointer transition-colors";
const width = fullWidth ? "w-full" : "";
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  target={target}
  class={`${base} ${variantClasses[variant]} ${variant !== "floating" ? sizeClasses[size] : ""} ${width} ${className}`.trim()}
>
  <slot />
</Tag>

---
interface Props {
  variant?: "primary" | "outline" | "floating" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  target?: string;
  fullWidth?: boolean;
  class?: string;
}

const {
  variant = "outline",
  size = "md",
  href,
  target,
  fullWidth = false,
  class: className = "",
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: "h-9 px-5 text-[11px]",
  md: "h-12 px-7 text-xs",
  lg: "h-14 px-9 text-sm",
};

const variantClasses: Record<string, string> = {
  primary:
    "bg-ink text-paper hover:bg-rust group/btn relative overflow-hidden",
  outline:
    "border border-ink text-ink hover:bg-ink hover:text-paper group/btn",
  floating:
    "bg-amber text-ink rounded-full p-4 shadow-elevated fixed bottom-8 right-5 lg:right-8 z-40 cursor-pointer hover:bg-ink hover:text-amber transition-colors",
  ghost:
    "text-ink hover:text-rust",
};

const base =
  "font-display tracking-[0.18em] uppercase inline-flex items-center justify-center gap-3 cursor-pointer transition-colors duration-300";
const width = fullWidth ? "w-full" : "";
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  target={target}
  class={`${base} ${variantClasses[variant]} ${variant !== "floating" ? sizeClasses[size] : ""} ${width} ${className}`.trim()}
>
  <slot />
  {variant !== "floating" && variant !== "ghost" && (
    <span class="inline-block transition-transform group-hover/btn:translate-x-1">→</span>
  )}
</Tag>

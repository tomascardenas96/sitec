---
interface Props {
  label: string;
  subtitle?: string;
  variant?: "default" | "inverse";
  hasIcon?: boolean;
  index?: string;
  class?: string;
}

const {
  label,
  subtitle,
  variant = "default",
  index,
  class: className = "",
} = Astro.props;

const isInverse = variant === "inverse";
const titleColor    = isInverse ? "text-paper" : "text-ink";
const subtitleColor = isInverse ? "text-paper/70" : "text-ink/60";
const labelColor    = isInverse ? "text-amber" : "text-rust";
const ruleColor     = isInverse ? "bg-paper/30" : "bg-ink/20";
---

<div class={`w-full ${className}`}>
  <div class="flex items-center gap-3 mb-4">
    <span class={`font-mono text-[11px] tracking-[0.28em] uppercase ${labelColor}`}>
      {index && <span class="mr-2">[{index}]</span>}
      § Sección
    </span>
    <span class={`flex-1 h-px ${ruleColor}`}></span>
  </div>

  <div class="grid lg:grid-cols-[1fr_auto] items-end gap-6">
    <h2 class={`font-display uppercase leading-[0.95] tracking-tight text-5xl md:text-6xl lg:text-7xl 2xl:text-8xl ${titleColor}`}>
      {label}
    </h2>

    {subtitle && (
      <p class={`font-serif italic text-lg lg:text-xl max-w-[36ch] ${subtitleColor} lg:text-right`}>
        {subtitle}
      </p>
    )}
  </div>
</div>

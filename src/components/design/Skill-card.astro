---
const { skill } = Astro.props;
---

<div class="grid grid-cols-[6rem_1fr] md:grid-cols-[5rem_1fr] gap-4 2xl:gap-6 md:gap-5">
  <div class="w-24 h-24 flex items-center justify-center">
    <img
      src={skill.icon}
      alt={skill.title}
      class="h-[5rem] md:h-[4rem] 2xl:h-[4.5rem] w-[5rem] md:w-[4rem] 2xl:w-[4.5rem]"
    />
  </div>

  <div class="flex flex-col gap-2 py-2">
    <h3 class="text-primary-500 font-oswald text-lg md:text-base font-semibold">
      {skill.title}
    </h3>
    <p class="text-sm md:text-xs 2xl:text-sm">{skill.subtitle}</p>
  </div>
</div>

---
const { item } = Astro.props;
---

<div
  class="grid grid-cols-[6rem_1fr] md:grid-cols-[5rem_1fr] xl:grid-cols-[9rem] 2xl:grid-cols-[10rem] xl:grid-rows-[7rem_7rem] xl:justify-center gap-5 md:gap-4 xl:gap-1 2xl:gap-0"
>
  <div
    class="rounded-full w-24 md:w-[5rem] xl:w-[7rem] h-24 md:h-[5rem] xl:h-[7rem] flex items-center justify-center xl:mx-auto"
  >
    <img
      src={item.icon}
      alt={item.title}
      class="h-11 md:h-9 xl:h-12 2xl:h-[3.5rem] w-11 md:w-9 xl:w-12 2xl:w-[3.5rem]"
    />
  </div>

  <div
    class="flex flex-col gap-2 xl:gap-1 2xl:gap-2 py-2 xl:p-0 xl:text-center xl:items-center"
  >
    <h3
      class="text-primary-500 font-oswald text-lg md:text-base xl:text-sm 2xl:text-base xl:max-w-[10ch] font-semibold 2xl:leading-5"
    >
      {item.title}
    </h3>
    <p
      class="text-sm md:text-xs xl:text-2xs 2xl:text-xs xl:max-w-[23ch] 2xl:leading-[1.15rem]"
    >
      {item.subtitle}
    </p>
  </div>
</div>

---
const phone = "5492281378525";
const text =
  "Buen día, quisiera solicitar un presupuesto para la instalación de paneles eléctricos en mi empresa. Muchas gracias.";
const encoded = encodeURIComponent(text);
---

<section
  class="h-72 lg:h-80 2xl:h-96 px-8 pb-8 flex flex-col justify-center items-center gap-2 font-oswald"
>
  <h1
    class="text-primary-500 text-xl font-semibold"
    data-reveal="fade-up"
  >
    ¿Te gustaría que trabajemos juntos?
  </h1>
  <p data-reveal="fade-up" data-reveal-delay="100">
    Solicita acá un presupuesto sin cargo
  </p>
  <button
    class="group font-oswald bg-primary-500 shadow-md w-full lg:max-w-[25rem] h-11 mt-3 rounded-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-elevated hover:brightness-110"
    data-reveal="fade-up"
    data-reveal-delay="200"
  >
    <a
      href={`https://wa.me/${phone}?text=${encoded}`}
      target="blank"
      class="w-full h-full flex justify-center items-center text-white"
    >
      SOLICITAR PRESUPUESTO
    </a>
  </button>
</section>

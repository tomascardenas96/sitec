---
const { professional, index = 0 } = Astro.props;
import FacebookIcon from "../../assets/icons/facebook.svg";
import InstagramIcon from "../../assets/icons/instagram.svg";
import LinkedinIcon from "../../assets/icons/linkedin.svg";
const delay = (index % 3) * 110;
---

<div
  class="group w-full md:w-[20.96rem] lg:w-full h-[32rem] lg:h-[24rem] border grid grid-rows-[17rem_14.5rem] md:grid-rows-[16rem_14.5rem] lg:grid-rows-[11rem_14.5rem] gap-2 md:shrink-0 bg-white overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-elevated"
  data-reveal="fade-up"
  data-reveal-delay={delay}
>
  <div class="overflow-hidden">
    <img
      src={professional.image.src}
      alt={professional.name}
      class="object-cover object-top h-[17rem] md:h-[16rem] lg:h-[11rem] w-full transition-transform duration-500 ease-out group-hover:scale-105"
    />
  </div>

  <div class="h-full p-5 lg:pt-1 lg:px-4 flex flex-col gap-1 md:gap-2 lg:gap-1">
    <h3
      class="text-center font-oswald text-2xl lg:text-sm transition-colors duration-200 group-hover:text-accent-500"
    >
      {professional.name.toUpperCase()}
    </h3>
    <p class="text-center font-oswald text-primary-500 text-xl lg:text-sm">
      {professional.role.toUpperCase()}
    </p>
    <p class="text-sm lg:text-xs lg:leading-[.9rem] text-center lg:my-1">
      {professional.description}
    </p>
    <div class="flex gap-1 justify-center items-center lg:mt-1">
      <div
        class="rounded-full h-8 w-8 shadow-card flex items-center justify-center border transition-all duration-200 hover:scale-110 hover:border-accent-500 cursor-pointer"
      >
        <FacebookIcon class="w-4 h-4 opacity-70" />
      </div>
      <div
        class="rounded-full h-8 w-8 shadow-card flex items-center justify-center border transition-all duration-200 hover:scale-110 hover:border-accent-500 cursor-pointer"
      >
        <InstagramIcon class="w-4 h-4 opacity-70" />
      </div>
      <div
        class="rounded-full h-8 w-8 shadow-card flex items-center justify-center border transition-all duration-200 hover:scale-110 hover:border-accent-500 cursor-pointer"
      >
        <LinkedinIcon class="w-4 h-4 opacity-70" />
      </div>
    </div>
  </div>
</div>

---
import Card from "../ui/Card.astro";
import Success from "../../assets/icons/success.svg";
const { value } = Astro.props;
---

<Card align="start">
  <div slot="media">
    <Success class="w-7 lg:w-6 h-7 lg:h-6" />
  </div>
  <h3 slot="header" class="font-oswald text-primary-500 text-sm lg:text-xs 2xl:text-sm font-semibold">
    {value.title.toUpperCase()}
  </h3>
  <p slot="body" class="text-neutral-800/60 text-sm lg:text-xs 2xl:text-sm">{value.subtitle}</p>
</Card>

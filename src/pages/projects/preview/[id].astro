---
import MainLayout from "../../../layouts/Main-layout.astro";
import { allProjects } from "../../../data/projects.js";
import TitlePage from "../../../components/common/Title-page.astro";

export async function getStaticPaths() {
  return allProjects.map((project) => ({
    params: { id: project.id.toString() },
  }));
}

const { id } = Astro.params;

const project = allProjects.find((p) => p.id.toString() === id);

if (!project) {
  Astro.redirect("/404");
}
---

<MainLayout>
  <TitlePage title="Proyectos" />
  <section class="max-w-2xl mx-auto px-4 py-10 lg:pb-16 lg:mt-4 text-center">
    <img
      src={project?.image.src}
      alt={project?.title}
      class="w-full max-h-[24rem] object-cover rounded-xs p-1 border border-primary-500 shadow-md mb-8"
      data-reveal="fade-up"
    />
    <h1
      class="text-3xl font-bold mb-4 font-oswald 2xl:font-normal text-primary-500"
      data-reveal="fade-up"
      data-reveal-delay="120"
    >
      {project?.title}
    </h1>
    <p
      class="text-gray-700 leading-relaxed mb-10"
      data-reveal="fade-up"
      data-reveal-delay="220"
    >
      {project?.description}
    </p>

    <button
      type="button"
      class="group bg-primary-500 text-white px-6 py-3 rounded-md transition-all duration-200 hover:bg-primary-700 hover:-translate-y-0.5 hover:shadow-elevated"
      onclick="window.history.back()"
      data-reveal="fade-up"
      data-reveal-delay="320"
    >
      <span class="inline-block transition-transform duration-200 group-hover:-translate-x-1">←</span> Volver
    </button>
  </section>
</MainLayout>
